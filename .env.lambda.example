# ──────────────────────────────────────────────────────────────────────────
# Remotion Lambda — environment variables
# Copy this file to `.env.local` (or `.env`) and fill in the values.
# Do NOT commit the filled-in file. `.env*` is gitignored by Next.js by default.
# ──────────────────────────────────────────────────────────────────────────

# ── AWS credentials (from the IAM user you create for Remotion) ───────────
# Created in AWS IAM → Users → remotion-user → Security credentials →
# "Create access key" → Application running outside AWS.
REMOTION_AWS_ACCESS_KEY_ID=
REMOTION_AWS_SECRET_ACCESS_KEY=

# ── AWS region where the Lambda function and S3 bucket live ──────────────
# Pick a region close to you (or your users) and use the same one everywhere.
# Examples: us-east-1, us-west-2, eu-central-1, ap-southeast-1
REMOTION_AWS_REGION=us-east-1

# ── Deployed Remotion Lambda function name ───────────────────────────────
# Populated after running: `npx remotion lambda functions deploy`
# The CLI prints a name like: remotion-render-4-0-448-mem2048mb-disk2048mb-240sec
REMOTION_AWS_FUNCTION_NAME=

# ── Deployed Remotion site (serve URL) ───────────────────────────────────
# Populated after running: `npx remotion lambda sites create compositions/index.ts --site-name=postshotclarity`
# Looks like: https://remotionlambda-useast1-xxxx.s3.us-east-1.amazonaws.com/sites/postshotclarity/index.html
REMOTION_AWS_SERVE_URL=

# ── (Optional) S3 bucket override ────────────────────────────────────────
# Remotion will auto-discover the bucket it created; set this only if you
# have multiple Remotion buckets in the region and need to pin one.
# REMOTION_AWS_BUCKET_NAME=
